# Port exposed by the container
PORT=3000

# Secret used to sign JWT session tokens - generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# TMDB API key (v3 auth), free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Initial admin account, created automatically on first boot if it doesn't exist yet
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
